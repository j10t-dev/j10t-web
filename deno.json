{
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-env=CHART_API_URL src/main.ts",
    "dev": "deno run --allow-net --allow-read --allow-env=CHART_API_URL --watch src/main.ts",
    "test": "deno test --allow-net --allow-read --allow-run --allow-env --allow-write",
    "bundle": "deno run -A build/esbuild.bundle.ts",
    "build-blog": "deno run --allow-read --allow-write --allow-env build/build-blog.ts"
  },
  "imports": {
    "@eta-dev/eta": "jsr:@eta-dev/eta@^3.5.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/front-matter": "jsr:@std/front-matter@^1.0.0",
    "@std/http": "jsr:@std/http@^1.0.17",
    "@std/media-types": "jsr:@std/media-types@^1.0.0",
    "@std/path": "jsr:@std/path@^1.1.0",
    "@deno/gfm": "jsr:@deno/gfm@^0.8.0",
    "@logtape/logtape": "jsr:@logtape/logtape@^0.7.0",
    "@luca/esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@^0.11.0",
    "esbuild": "npm:esbuild@^0.24.0",
    "vega-lite": "https://esm.sh/vega-lite@6.2.0",
    "vega-lite@5": "https://esm.sh/vega-lite@5.16.3",
    "zod": "npm:zod@^3.24.1"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["dom", "esnext", "deno.ns"]
  }
}
